# SERVER
NODE_ENV="(development/production/test)"
PORT=5500       # Server listening to which PORT number
API_V="/v1"     # API Version

# MongoDB
MONGO_URI="your_mongodb_connection_string"

# CORS  (The URLs trying to access the server)
CORS_ORIGIN="comma_separated_cross_origins_for_resource_sharing"

# LLM (Gemini)
GEMINI_API_KEY="your_gemini_api_key"